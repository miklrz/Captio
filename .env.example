CAPTIO_ENV=development
CAPTIO_DATA_DIR=data
DATABASE_URL=sqlite:///data/captio.db
CAPTIO_JWT_SECRET=replace-with-a-long-random-secret
CAPTIO_JWT_EXPIRES_HOURS=24
CAPTIO_WHISPER_MODEL=base
CAPTIO_MAX_UPLOAD_SIZE_MB=512
CAPTIO_CLEANUP_UPLOADS_AFTER_HOURS=24
CAPTIO_ALLOWED_VIDEO_EXTENSIONS=.mp4,.mov,.mkv,.webm,.avi,.mp3,.wav,.m4a
CAPTIO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CAPTIO_SEED_DEMO_USERS=true
CAPTIO_DEMO_ADMIN_LOGIN=admin
CAPTIO_DEMO_ADMIN_PASSWORD=replace-demo-admin-password
CAPTIO_DEMO_USER_LOGIN=paimon
CAPTIO_DEMO_USER_PASSWORD=replace-demo-user-password
REACT_APP_API_BASE_URL=http://localhost:8000
